## Example environment variables for local development
# Copy this to `.env` and fill values where needed

# Google Gemini API
# Obter em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Database (Postgres example)
# Example: postgres://user:password@localhost:5432/bragdev?sslmode=disable
DB_URL=
DB_USERNAME=
DB_PASSWORD=
DB_DRIVER=
DB_DIALECT=

# JWT secret
JWT_SECRET=

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Redirect URI registered in GitHub App (backend callback)
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback
# Frontend redirect after successful login
OAUTH_FRONTEND_REDIRECT=http://localhost:4200/auth-callback

# Cookies - adjust for your environment
# In production, always serve over HTTPS and enable `APP_COOKIE_SECURE=true`.
# For local development with localhost you may set `APP_COOKIE_SECURE=false`.
APP_COOKIE_DOMAIN=localhost
APP_COOKIE_SECURE=true
APP_COOKIE_SAME_SITE=Lax

# App
PORT=8080
MIGRATE=true
